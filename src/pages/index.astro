---
import Gallery from "../components/Gallery.svelte";

const photos = [
  { src: "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?w=800", alt: "Forest light",  title: "Forest light" },
  { src: "https://images.unsplash.com/photo-1470770841072-f978cf4d019e?w=800", alt: "Lake reflection", title: "Lake reflection" },
  { src: "https://images.unsplash.com/photo-1518173946687-a4c8892bbd9f?w=800", alt: "Mountain mist",  title: "Mountain mist" },
  { src: "https://images.unsplash.com/photo-1502082553048-f009c37129b9?w=800", alt: "Autumn trail",   title: "Autumn trail" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Fine Art Photography — photo_folio_2</title>
  </head>
  <body>
    <header>
      <h1>Fine Art Photography</h1>
      <p>A scaffolded portfolio — Astro + Svelte on Cloudflare.</p>
    </header>
    <main>
      <Gallery photos={photos} client:load />
    </main>

    <style is:global>
      :root { color-scheme: light dark; }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        background: #0b0b0c;
        color: #ececec;
      }
      header { padding: 3rem 1.5rem 1.5rem; max-width: 1100px; margin: 0 auto; }
      header h1 { font-weight: 300; letter-spacing: 0.02em; margin: 0 0 0.25rem; }
      header p { opacity: 0.7; margin: 0; }
      main { padding: 1.5rem; max-width: 1100px; margin: 0 auto; }
    </style>
  </body>
</html>
