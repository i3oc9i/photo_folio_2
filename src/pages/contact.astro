---
import ContactForm from "../components/ContactForm.svelte";
const sent = Astro.url.searchParams.get("sent") === "1";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Contact — photo_folio_2</title>
  </head>
  <body>
    <header>
      <h1>Contact</h1>
      <p>Reach out about prints, commissions, or just to say hello.</p>
      <nav>
        <a href="/">Work</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>
    <main>
      {sent && <p class="msg ok">Thanks — message sent.</p>}
      <ContactForm client:load />
    </main>

    <style is:global>
      :root { color-scheme: light dark; }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        background: #0b0b0c;
        color: #ececec;
      }
      header { padding: 3rem 1.5rem 1.5rem; max-width: 1100px; margin: 0 auto; }
      header h1 { font-weight: 300; letter-spacing: 0.02em; margin: 0 0 0.25rem; }
      header p { opacity: 0.7; margin: 0 0 1rem; }
      header nav { display: flex; gap: 1.25rem; }
      header nav a { color: inherit; text-decoration: none; opacity: 0.8; }
      header nav a:hover { opacity: 1; text-decoration: underline; }
      main { padding: 1.5rem; max-width: 1100px; margin: 0 auto; }
      .msg.ok { color: #7ee787; }
    </style>
  </body>
</html>
