---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.svelte";
const sent = Astro.url.searchParams.get("sent") === "1";
---

<Layout pageTitle="Contact">
  <section class="intro">
    <h1>Get in touch</h1>
    <p>Print enquiries, commissions, or just to say hello.</p>
  </section>

  {sent && <p class="msg ok">Thanks — message sent.</p>}
  <ContactForm client:load />

  <style>
    .intro h1 {
      font-weight: 300;
      font-size: clamp(1.75rem, 3vw, 2.5rem);
      letter-spacing: 0.02em;
      margin: 0 0 0.25rem;
    }
    .intro p { opacity: 0.7; margin: 0 0 2rem; }
    .msg.ok { color: #7ee787; }
  </style>
</Layout>
