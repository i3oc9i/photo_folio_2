---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const photos = await getCollection("photos");
  return photos.map((photo) => ({
    params: { slug: photo.id },
    props: { photo },
  }));
}

const { photo } = Astro.props;
const project = await getEntry(photo.data.project);
const story = photo.data.story ? await getEntry(photo.data.story) : null;
---

<Layout pageTitle={photo.data.title} description={photo.data.alt}>
  <article class="photo">
    <figure>
      <img src={photo.data.image} alt={photo.data.alt} />
      <figcaption>
        <h1>{photo.data.title}</h1>
        <p class="meta">
          {project && (
            <>
              <a href={`/projects/${project.id}/`}>{project.data.title}</a>
              {(photo.data.location || photo.data.year) && " · "}
            </>
          )}
          {photo.data.location}
          {photo.data.location && photo.data.year && ", "}
          {photo.data.year}
        </p>
      </figcaption>
    </figure>

    {photo.data.exif && (
      <dl class="exif">
        {photo.data.exif.camera && (<><dt>Camera</dt><dd>{photo.data.exif.camera}</dd></>)}
        {photo.data.exif.lens && (<><dt>Lens</dt><dd>{photo.data.exif.lens}</dd></>)}
        {photo.data.exif.focalLength && (<><dt>Focal length</dt><dd>{photo.data.exif.focalLength}</dd></>)}
        {photo.data.exif.aperture && (<><dt>Aperture</dt><dd>{photo.data.exif.aperture}</dd></>)}
        {photo.data.exif.shutter && (<><dt>Shutter</dt><dd>{photo.data.exif.shutter}</dd></>)}
        {photo.data.exif.iso && (<><dt>ISO</dt><dd>{photo.data.exif.iso}</dd></>)}
      </dl>
    )}

    {story && (
      <p class="story-link">
        <a href={`/stories/${story.id}/`}>Read the story → {story.data.title}</a>
      </p>
    )}
  </article>

  <style>
    figure { margin: 0; }
    figure img {
      display: block;
      width: 100%;
      max-height: 80vh;
      object-fit: contain;
      background: #000;
      border-radius: 2px;
    }
    figcaption { margin-top: 1rem; }
    figcaption h1 {
      font-weight: 400;
      font-size: 1.4rem;
      margin: 0 0 0.25rem;
    }
    .meta { margin: 0; opacity: 0.7; font-size: 0.9rem; }
    .meta a { color: #9bb1ff; text-decoration: none; }
    .meta a:hover { text-decoration: underline; }
    dl.exif {
      display: grid;
      grid-template-columns: max-content 1fr;
      gap: 0.35rem 1rem;
      margin: 2rem 0;
      font-size: 0.9rem;
      max-width: 24rem;
    }
    dl.exif dt { opacity: 0.6; }
    dl.exif dd { margin: 0; }
    .story-link a {
      color: #9bb1ff;
      text-decoration: none;
      font-size: 0.95rem;
    }
    .story-link a:hover { text-decoration: underline; }
  </style>
</Layout>
