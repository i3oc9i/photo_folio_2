---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const stories = await getCollection("stories");
  const photos = await getCollection("photos");

  return stories.map((story) => {
    const linkedPhotos = photos.filter((p) => p.data.story?.id === story.id);
    return {
      params: { slug: story.id },
      props: { story, linkedPhotos },
    };
  });
}

const { story, linkedPhotos } = Astro.props;
const { Content } = await render(story);
---

<Layout pageTitle={story.data.title} description={story.data.excerpt}>
  <article class="story">
    <header>
      <h1>{story.data.title}</h1>
      {story.data.date && (
        <time datetime={story.data.date.toISOString()}>
          {story.data.date.toLocaleDateString("en-GB", {
            year: "numeric", month: "long", day: "numeric",
          })}
        </time>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>

    {linkedPhotos.length > 0 && (
      <section class="related">
        <h2>The photographs</h2>
        <ul>
          {linkedPhotos.map((p) => (
            <li>
              <a href={`/photos/${p.id}/`}>
                <img src={p.data.image} alt={p.data.alt} loading="lazy" />
                <span>{p.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>

  <style>
    .story { max-width: 38rem; }
    .story h1 {
      font-weight: 300;
      font-size: clamp(1.75rem, 3vw, 2.25rem);
      letter-spacing: 0.02em;
      margin: 0 0 0.35rem;
    }
    .story time { opacity: 0.6; font-size: 0.85rem; }
    .prose { margin-top: 1.5rem; }
    .prose :global(p) { margin: 0 0 1rem; }
    .prose :global(h2) { font-weight: 400; margin: 2rem 0 0.5rem; font-size: 1.15rem; }

    .related { margin-top: 3rem; max-width: none; }
    .related h2 {
      font-weight: 400;
      font-size: 1rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      opacity: 0.7;
    }
    .related ul {
      list-style: none;
      padding: 0;
      margin: 1rem 0 0;
      display: grid;
      gap: 0.75rem;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    }
    .related a {
      display: block;
      text-decoration: none;
      color: inherit;
    }
    .related img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      border-radius: 2px;
    }
    .related span { display: block; margin-top: 0.4rem; font-size: 0.85rem; opacity: 0.8; }
  </style>
</Layout>
