---
import { getEntry } from "astro:content";

interface Props {
  pageTitle?: string;
  description?: string;
}

const { pageTitle, description } = Astro.props;

const siteEntry = await getEntry("site", "main");
if (!siteEntry) throw new Error("Missing src/content/site/main.md");
const site = siteEntry.data;

const fullTitle = pageTitle
  ? `${pageTitle} — ${site.title}`
  : site.tagline
    ? `${site.title} — ${site.tagline}`
    : site.title;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <header class="site">
      <a href="/" class="brand">
        <span class="name">{site.title}</span>
        {site.tagline && <span class="tagline">{site.tagline}</span>}
      </a>
      <nav>
        <a href="/">Work</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>

    <main><slot /></main>

    <footer class="site">
      {site.social.length > 0 && (
        <ul class="social">
          {site.social.map((s) => (
            <li>
              <a href={s.url} target="_blank" rel="noopener noreferrer">{s.label}</a>
            </li>
          ))}
        </ul>
      )}
      <small>© {new Date().getFullYear()} {site.title}</small>
    </footer>

    <style is:global>
      :root { color-scheme: light dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        background: #0b0b0c;
        color: #ececec;
        line-height: 1.55;
      }
      a { color: inherit; }
      header.site {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 1.25rem;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: baseline;
        justify-content: space-between;
      }
      header.site .brand { text-decoration: none; display: flex; flex-direction: column; gap: 0.15rem; }
      header.site .name { font-size: 1.05rem; letter-spacing: 0.04em; text-transform: uppercase; }
      header.site .tagline { font-size: 0.8rem; opacity: 0.6; }
      header.site nav { display: flex; gap: 1.25rem; font-size: 0.9rem; }
      header.site nav a { text-decoration: none; opacity: 0.75; }
      header.site nav a:hover { opacity: 1; }
      main {
        max-width: 1100px;
        margin: 0 auto;
        padding: 1.5rem;
      }
      footer.site {
        max-width: 1100px;
        margin: 4rem auto 0;
        padding: 2rem 1.5rem 3rem;
        border-top: 1px solid #1f1f22;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: space-between;
        font-size: 0.85rem;
        opacity: 0.7;
      }
      footer.site ul.social {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: 1.25rem;
      }
      footer.site ul.social a { text-decoration: none; }
      footer.site ul.social a:hover { text-decoration: underline; }
    </style>
  </body>
</html>
